<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Qwen359b.Views.MediaViewerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Qwen359b.ViewModels"
      xmlns:converters="clr-namespace:Qwen359b.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="{Binding SelectedItem.FileName, StringFormat='Viewing: {0}'}">

    <Page.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Media Display Area (Image or Video Player) -->
        <Border Grid.Row="0" Name="MediaDisplayArea" Background="Black">
            <Grid>
                <!-- Image Presenter -->
                <Image Name="ImagePresenter" 
                       Stretch="Uniform"/>
                
                <!-- Video Placeholder -->
                <TextBlock Name="VideoPresenter"
                           Text="Video Player Placeholder"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Controls/Info Footer -->
        <StackPanel Grid.Row="1" Margin="15" Background="LightGray">
            <TextBlock x:Name="MediaTitleLabel" 
                       Text="{Binding SelectedItem.FileName}" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <Button Content="Back to Gallery" Click="GoBack_Clicked" Padding="10,5" />
        </StackPanel>
    </Grid>
</Page>