<Page x:Class="Qwen359b.Views.GalleryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Qwen359b.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Media Gallery">

    <Page.Resources>
        <DataTemplate x:Key="MediaItemTemplate">
            <Border Margin="5" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1">
                <Grid Height="220">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Thumbnail/Image Display Area -->
                    <Image Grid.Row="0"
                           Source="{Binding ThumbnailSource}"
                           Stretch="UniformToFill"/>
                    
                    <!-- File Info Footer -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding FileName}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="5,5,5,5"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Top Bar for View Mode Toggling -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Height="50" Margin="10">
            <Button Content="View All Media" Click="ToggleGalleryView_Clicked" Padding="10,5" Margin="5"/>
            <Button Content="Select Item" Click="ToggleSelectionMode_Clicked" Padding="10,5" Margin="5"/>
        </StackPanel>

        <!-- Gallery View (Grid/List) -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding MediaItems}"
                 ItemTemplate="{StaticResource MediaItemTemplate}"
                 SelectionMode="Single"
                 SelectedItem="{Binding SelectedMediaItem}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>