<Window x:Class="Qwen359bVisitingCardScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Qwen359bVisitingCardScan"
        mc:Ignorable="d"
        Title="Visiting Card Scanner" Height="600" Width="800">
    <DockPanel>
        <TabControl>
            <TabItem Header="Gallery">
                <Frame NavigationUIVisibility="Hidden" Source="pack://application:,,,/Views/GalleryView.xaml" />
            </TabItem>
            <TabItem Header="Viewer">
                <Frame NavigationUIVisibility="Hidden" Source="pack://application:,,,/Views/MediaViewerView.xaml" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
